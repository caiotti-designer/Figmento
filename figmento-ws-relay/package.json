{
  "name": "figmento-ws-relay",
  "version": "1.0.0",
  "description": "WebSocket relay server bridging Figmento MCP server and Figma plugin",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/copy-knowledge.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "predev": "node -e \"const {execSync}=require('child_process');try{const r=execSync('netstat -ano').toString();const m=r.match(/TCP.*:3055.*LISTENING\\s+(\\d+)/);if(m){execSync('taskkill /PID '+m[1]+' /F',{stdio:'ignore'});console.log('[predev] Freed port 3055');}}catch(e){}\"",
    "dev": "node scripts/copy-knowledge.js && tsc && node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "puppeteer": "^24.38.0",
    "typescript": "^5.3.3"
  }
}
